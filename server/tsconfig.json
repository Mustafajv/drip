{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "..",
    "resolveJsonModule": true,
    "declaration": true,
    "types": ["node"]
  },
  "include": ["./**/*.ts", "../generated/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
